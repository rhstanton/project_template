# Ignore all files but include directories
*
!*/

# Files to include
!/.gitignore
!/LICENSE
!/CITATION.cff
!/CHANGELOG.md
!/QUICKSTART.md
!/TEMPLATE_USAGE.md
!/JOURNAL_EXCLUDE
!/DATA_AVAILABILITY.md
!pyproject.toml
!README*
!flake.nix
!flake.lock
!.vscode/
!*.ado
!*.do
!*.ipynb
!*.json
!*.jl
!*.md
!*.py
!*.sh
!*.toml
!*.txt
!*.yml
!run*
!Makefile
!uv.lock
!Dockerfile
!.dockerignore

# Directories to exclude completely
paper/

# Replication package (created by make journal-package, separate directory)
replication-package/

# Journal package artifacts (created by make journal-package)
journal-package/
journal-package.tar.gz
journal-package.zip

# Build marker (internal make state)
.make_build_marker

# ── Private maintainer overlay (see also .dockerignore, JOURNAL_EXCLUDE) ──────
# Real files live in `private/`, a nested, SEPARATE git repo (gitignored here).
# Gitignored symlinks at the public root point into it; set up / repaired by
# `make private-init` (scripts/init-private.sh). No trailing slashes, so each
# pattern matches the SYMLINK (which git sees as a file) as well as a real
# file/dir. These sit AFTER the `!*.md` / `!*.json` / `!*/` includes above, so
# they re-ignore the symlinks that those includes would otherwise track.
# `private` likewise overrides `!*/` so git never descends into the private repo.
private
dev-notes
COAUTHOR_SETUP.md

# AI-tool files — kept entirely in private/ai/. The public repo ships no AI
# guidance, settings, or rule files. `make private-init` creates gitignored
# symlinks at the canonical paths so the maintainer's tools find their config.
AGENTS.md
CLAUDE.md
.claude
.github/copilot-instructions.md
.aider*
.cursor*
.tabnine

# Maintainer-only docs that sit inside otherwise-public dirs (symlinked from
# private/ when present). Listed explicitly so they're ignored either way.
docs/NOTEBOOK_SUPPORT_IMPLEMENTATION.md
tests/NOTEBOOK_TESTS_SUMMARY.md
tests/TEST_IMPROVEMENTS.md

# Environment directories (generated, platform-specific)
.venv/
.env/
.julia/
.cache/
.stata/
env/Manifest.toml
env/lock.pid

# Python cache
__pycache__/
*.pyc
*.pyo
env/pyjuliapkg/
env/.CondaPkg/

# Generated outputs
output/

# Test coverage reports
htmlcov/
.coverage
.pytest_cache/

# Data directories (structured with placeholders for larger projects)
# Uncomment and customize as needed:
# data/raw/*
# !data/raw/.gitignore
# !data/raw/README.md
# data/processed/*
# !data/processed/.gitignore
# !data/processed/README.md

# Python/Julia artifacts
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.CondaPkg/

# Editor artifacts
.#*
flycheck*
_region*
*.swp
*.swo
*~
.idea/

# OS artifacts
.DS_Store
Thumbs.db

# Build/temp artifacts
*.log
*.aux
