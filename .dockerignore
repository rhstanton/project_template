# Generated / platform-specific environment dirs (rebuilt inside the image)
.venv/
.env/
.julia/
.stata/
.cache/

# Generated, platform-specific Julia env files — must NOT be copied from the host
# (they belong to the host's Julia/OpenSSL, which differ from the container's, and
# would clobber the env the image builds for itself).
env/Manifest.toml
env/pyjuliapkg/
env/.CondaPkg/
env/lock.pid

# Build outputs (regenerated by `make all` in the container)
output/
paper/

# Journal-package artifacts
replication-package/
replication-package.tar.gz
replication-package.zip

# Private maintainer overlay (not needed to reproduce; also keeps the nested
# private/ repo and its symlinks out of the image — the symlinks would dangle).
private/
dev-notes
AGENTS.local.md
COAUTHOR_SETUP.md
.claude/

# Caches & cruft
__pycache__/
**/*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.make_build_marker
.DS_Store

# Note: .git IS included (3 MB) so in-container provenance records the source commit
# and `git submodule` works offline.
